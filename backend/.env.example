# Aether backend environment variables
# Copy this file to `.env` for local development.

# REQUIRED: Postgres connection string
# Render: use the "Internal Database URL" from your Render Postgres instance
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# RECOMMENDED: JWT signing secret (use a long random value in production)
JWT_SECRET=change-me-to-a-long-random-string

# OPTIONAL: HTTP port to listen on (Render will set PORT automatically)
PORT=8080

# OPTIONAL (required for background push notifications): Firebase Admin credentials
# For local dev you can point to a service account JSON file:
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json

# Alternatively, set FIREBASE_SERVICE_ACCOUNT_JSON to the full JSON string.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
